generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Golongan {
  PNS
  CPNS
  PPPK
  HONORER
}

enum JenisKelamin {
  L
  P
}

enum StatusPegawai {
  AKTIF
  NONAKTIF
}

model Pegawai {
  id           String         @id @default(cuid())
  nip          String         @unique
  nama         String
  jabatan      String
  golRuang     String
  golongan     Golongan
  jenisKelamin JenisKelamin   @map("jenis_kelamin")
  eselonisasi  String?
  unitBagian   String?
  tanggalMasuk DateTime       @default(now()) @map("tanggal_masuk")
  status       StatusPegawai  @default(AKTIF)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@map("pegawai")
}
